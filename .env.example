# .env.example — copy to .env and fill in your values

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=xlventures-memory
LOG_LEVEL=INFO

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xlventures
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_EPISODIC_DB=0
REDIS_CELERY_DB=1
EPISODIC_TTL_SECONDS=2592000

# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY=          # Required only for Qdrant Cloud
QDRANT_COLLECTION_NAME=companies
QDRANT_VECTOR_SIZE=1536

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Celery ─────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
